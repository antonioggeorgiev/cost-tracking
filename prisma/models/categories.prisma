model Category {
  id                 String                     @id @default(cuid())
  spaceId            String?                    @map("workspaceId")
  name               String
  slug               String
  parentCategoryId   String?
  isArchived         Boolean                    @default(false)
  sortOrder          Int                        @default(0)
  color              String?
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt
  space              Space?                     @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  parentCategory     Category?                  @relation("CategoryTree", fields: [parentCategoryId], references: [id], onDelete: SetNull)
  childCategories    Category[]                 @relation("CategoryTree")
  expenses           Expense[]
  recurringTemplates RecurringExpenseTemplate[]

  @@unique([spaceId, parentCategoryId, slug])
  @@index([spaceId, parentCategoryId, isArchived])
  @@index([parentCategoryId, isArchived])
}

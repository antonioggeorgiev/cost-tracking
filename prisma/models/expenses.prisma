model Expense {
  id                    String                    @id @default(cuid())
  spaceId               String                    @map("workspaceId")
  categoryId            String?
  createdByUserId       String
  paidByUserId          String?
  title                 String
  description           String?
  originalAmountMinor   Int
  originalCurrencyCode  String
  workspaceAmountMinor  Int
  workspaceCurrencyCode String
  exchangeRate          Decimal                   @db.Decimal(18, 8)
  exchangeRateDate      DateTime
  expenseDate           DateTime
  type                  ExpenseType               @default(one_time)
  status                ExpenseStatus             @default(posted)
  recurringTemplateId   String?
  debtAccountId         String?
  notes                 String?
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt
  space                 Space                     @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  category              Category?                 @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  createdByUser         User                      @relation("ExpenseCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  paidByUser            User?                     @relation("ExpensePaidBy", fields: [paidByUserId], references: [id], onDelete: Restrict)
  recurringTemplate     RecurringExpenseTemplate? @relation(fields: [recurringTemplateId], references: [id], onDelete: SetNull)
  debtAccount           DebtAccount?              @relation(fields: [debtAccountId], references: [id], onDelete: SetNull)
  debtPayment           DebtPayment?
  attachments           ExpenseAttachment[]
  splits                ExpenseSplit[]

  @@index([spaceId, expenseDate])
  @@index([spaceId, status, expenseDate])
  @@index([spaceId, categoryId, expenseDate])
  @@unique([recurringTemplateId, expenseDate])
}

model ExpenseSplit {
  id               String    @id @default(cuid())
  expenseId        String
  userId           String
  shareAmountMinor Int
  settled          Boolean   @default(false)
  settledAt        DateTime?
  createdAt        DateTime  @default(now())

  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user    User    @relation("ExpenseSplitUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([expenseId, userId])
  @@index([userId, settled])
  @@index([expenseId])
}

model RecurringExpenseTemplate {
  id                    String               @id @default(cuid())
  spaceId               String               @map("workspaceId")
  categoryId            String
  createdByUserId       String
  kind                  RecurringTemplateKind @default(fixed_amount)
  title                 String
  description           String?
  originalAmountMinor   Int?
  originalCurrencyCode  String
  workspaceAmountMinor  Int?
  workspaceCurrencyCode String
  exchangeRate          Decimal?             @db.Decimal(18, 8)
  exchangeRateDate      DateTime?
  frequency             RecurringFrequency
  interval              Int                  @default(1)
  anchorDays            Int[]                @default([])
  startDate             DateTime
  endDate               DateTime?
  nextOccurrenceDate    DateTime
  lastGeneratedAt       DateTime?
  defaultStatus         ExpenseStatus        @default(posted)
  isActive              Boolean              @default(true)
  paymentUrl            String?
  notes                 String?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  space                 Space                @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  category              Category             @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  createdByUser         User                 @relation("RecurringTemplateCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  expenses              Expense[]

  @@index([spaceId, nextOccurrenceDate, isActive])
}

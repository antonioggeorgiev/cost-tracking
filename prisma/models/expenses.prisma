model Expense {
  id                    String                    @id @default(cuid())
  workspaceId           String
  categoryId            String?
  createdByUserId       String
  title                 String
  description           String?
  originalAmountMinor   Int
  originalCurrencyCode  String
  workspaceAmountMinor  Int
  workspaceCurrencyCode String
  exchangeRate          Decimal                   @db.Decimal(18, 8)
  exchangeRateDate      DateTime
  expenseDate           DateTime
  type                  ExpenseType               @default(one_time)
  status                ExpenseStatus             @default(posted)
  recurringTemplateId   String?
  debtAccountId         String?
  notes                 String?
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt
  workspace             Workspace                 @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  category              Category?                 @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  createdByUser         User                      @relation("ExpenseCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  recurringTemplate     RecurringExpenseTemplate? @relation(fields: [recurringTemplateId], references: [id], onDelete: SetNull)
  debtAccount           DebtAccount?              @relation(fields: [debtAccountId], references: [id], onDelete: SetNull)
  debtPayment           DebtPayment?
  attachments           ExpenseAttachment[]

  @@index([workspaceId, expenseDate])
  @@index([workspaceId, status, expenseDate])
  @@index([workspaceId, categoryId, expenseDate])
  @@unique([recurringTemplateId, expenseDate])
}

model RecurringExpenseTemplate {
  id                    String               @id @default(cuid())
  workspaceId           String
  categoryId            String
  createdByUserId       String
  kind                  RecurringTemplateKind @default(fixed_amount)
  title                 String
  description           String?
  originalAmountMinor   Int?
  originalCurrencyCode  String
  workspaceAmountMinor  Int?
  workspaceCurrencyCode String
  exchangeRate          Decimal?             @db.Decimal(18, 8)
  exchangeRateDate      DateTime?
  frequency             RecurringFrequency
  interval              Int                  @default(1)
  anchorDays            Int[]                @default([])
  startDate             DateTime
  endDate               DateTime?
  nextOccurrenceDate    DateTime
  lastGeneratedAt       DateTime?
  defaultStatus         ExpenseStatus        @default(posted)
  isActive              Boolean              @default(true)
  paymentUrl            String?
  notes                 String?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  workspace             Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  category              Category             @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  createdByUser         User                 @relation("RecurringTemplateCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  expenses              Expense[]

  @@index([workspaceId, nextOccurrenceDate, isActive])
}

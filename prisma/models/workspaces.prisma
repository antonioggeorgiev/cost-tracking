model Space {
  id                 String              @id @default(cuid())
  name               String
  slug               String              @unique
  baseCurrencyCode   String
  createdByUserId    String
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  createdByUser      User                @relation("SpaceCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  memberships        SpaceMembership[]
  invites            SpaceInvite[]
  categories         Category[]
  expenses           Expense[]
  recurringTemplates RecurringExpenseTemplate[]
  debtAccounts       DebtAccount[]
  debtPayments       DebtPayment[]

  @@map("Workspace")
}

model SpaceMembership {
  id        String    @id @default(cuid())
  spaceId   String    @map("workspaceId")
  userId    String
  role      SpaceRole
  createdAt DateTime  @default(now())
  space     Space     @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([spaceId, userId])
  @@index([userId])
  @@map("WorkspaceMembership")
}

model SpaceInvite {
  id               String       @id @default(cuid())
  spaceId          String       @map("workspaceId")
  email            String
  role             SpaceRole
  token            String       @unique
  status           InviteStatus @default(pending)
  expiresAt        DateTime
  invitedByUserId  String
  acceptedByUserId String?
  acceptedAt       DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  space            Space        @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  invitedByUser    User         @relation("InviteSender", fields: [invitedByUserId], references: [id], onDelete: Restrict)
  acceptedByUser   User?        @relation("InviteAcceptor", fields: [acceptedByUserId], references: [id], onDelete: SetNull)

  @@index([spaceId, email, status])
  @@map("WorkspaceInvite")
}

model DebtAccount {
  id                  String          @id @default(cuid())
  spaceId             String          @map("workspaceId")
  kind                DebtAccountKind @default(bank_loan)
  direction           DebtDirection   @default(i_owe)
  name                String
  provider            String?
  counterparty        String?
  originalAmountMinor         Int
  currencyCode                String
  currentBalanceMinor         Int
  workspaceAmountMinor        Int
  workspaceCurrencyCode       String
  workspaceBalanceMinor       Int
  exchangeRate                Decimal             @db.Decimal(18, 8)
  exchangeRateDate            DateTime
  interestRateBps             Int?
  termMonths                  Int?
  monthlyAmountMinor          Int?
  residualValueMinor          Int?
  workspaceMonthlyAmountMinor Int?
  workspaceResidualValueMinor Int?
  frequency           RecurringFrequency?
  interval            Int?
  anchorDays          Int[]
  nextPaymentDate     DateTime?
  openedAt            DateTime
  isActive            Boolean         @default(true)
  notes               String?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  space               Space           @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  expenses            Expense[]
  payments            DebtPayment[]

  @@index([spaceId, isActive])
}

model DebtPayment {
  id                    String      @id @default(cuid())
  spaceId               String      @map("workspaceId")
  debtAccountId         String
  expenseId             String?     @unique
  paidByUserId          String
  originalAmountMinor   Int
  originalCurrencyCode  String
  workspaceAmountMinor  Int
  workspaceCurrencyCode String
  exchangeRate          Decimal     @db.Decimal(18, 8)
  exchangeRateDate      DateTime
  paymentDate           DateTime
  dueDate               DateTime?
  notes                 String?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  space                 Space       @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  debtAccount           DebtAccount @relation(fields: [debtAccountId], references: [id], onDelete: Cascade)
  expense               Expense?    @relation(fields: [expenseId], references: [id], onDelete: SetNull)
  paidByUser            User        @relation("DebtPaymentCreator", fields: [paidByUserId], references: [id], onDelete: Restrict)

  @@unique([debtAccountId, dueDate])
  @@index([spaceId, paymentDate])
  @@index([debtAccountId, dueDate])
}

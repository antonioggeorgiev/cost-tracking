model User {
  id                 String                     @id @default(cuid())
  clerkUserId        String                     @unique
  email              String                     @unique
  name               String?
  imageUrl           String?
  isPlatformAdmin    Boolean                    @default(false)
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt
  createdSpaces      Space[]                    @relation("SpaceCreator")
  memberships        SpaceMembership[]
  sentInvites        SpaceInvite[]              @relation("InviteSender")
  acceptedInvites    SpaceInvite[]              @relation("InviteAcceptor")
  expenses           Expense[]                  @relation("ExpenseCreator")
  paidExpenses       Expense[]                  @relation("ExpensePaidBy")
  recurringTemplates RecurringExpenseTemplate[]  @relation("RecurringTemplateCreator")
  debtPayments       DebtPayment[]              @relation("DebtPaymentCreator")
  expenseSplits      ExpenseSplit[]             @relation("ExpenseSplitUser")
}
